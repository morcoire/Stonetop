.stonetop-prosperity-field input {
  width: 60px;
  margin-left: 6px;
}

/* ========== STAGE 1: UNDEFINED POOL ========== */

.stonetop-undefined-pool {
  align-items: center;
  display: flex;
  margin-bottom: 16px;
}

.stonetop-undefined-tracker {
  margin: 0 0 0 10px;
}

.stonetop-undefined-tracker input[type="checkbox"] {
  margin-right: 6px;
}

/* ========== STAGE 1: SUPPLY USE TRACKERS ========== */

.stonetop-supply-uses {
  margin: 0 0 14px 0;
  padding-left: 4px;
}

.stonetop-supply-uses input[type="checkbox"] {
  margin-right: 4px;
}

.stonetop-supply-t0,
.stonetop-supply-t1,
.stonetop-supply-t2 {
  opacity: 0.35;
}

input[name="attr_prospmirror"][value="-1"] ~ .stonetop-row .stonetop-supply-t0,
input[name="attr_prospmirror"][value="-1"] ~ .stonetop-row .stonetop-supply-t1,
input[name="attr_prospmirror"][value="-1"] ~ .stonetop-row .stonetop-supply-t2 {
  pointer-events: none;
}

input[name="attr_prospmirror"][value="0"] ~ .stonetop-row .stonetop-supply-t0 {
  opacity: 1;
}
input[name="attr_prospmirror"][value="0"] ~ .stonetop-row .stonetop-supply-t1,
input[name="attr_prospmirror"][value="0"] ~ .stonetop-row .stonetop-supply-t2 {
  pointer-events: none;
}

input[name="attr_prospmirror"][value="1"] ~ .stonetop-row .stonetop-supply-t0,
input[name="attr_prospmirror"][value="1"] ~ .stonetop-row .stonetop-supply-t1 {
  opacity: 1;
}
input[name="attr_prospmirror"][value="1"] ~ .stonetop-row .stonetop-supply-t2 {
  pointer-events: none;
}

input[name="attr_prospmirror"][value="2"] ~ .stonetop-row .stonetop-supply-t0,
input[name="attr_prospmirror"][value="2"] ~ .stonetop-row .stonetop-supply-t1,
input[name="attr_prospmirror"][value="2"] ~ .stonetop-row .stonetop-supply-t2 {
  opacity: 1;
}

.stonetop-load-normal,
.stonetop-load-heavy {
  opacity: 0.35;
}

input[name="attr_loadmirror"][value="light"] ~ .stonetop-row .stonetop-load-normal,
input[name="attr_loadmirror"][value="light"] ~ .stonetop-row .stonetop-load-heavy {
  pointer-events: none;
}

input[name="attr_loadmirror"][value="normal"] ~ .stonetop-row .stonetop-load-normal {
  opacity: 1;
}
input[name="attr_loadmirror"][value="normal"] ~ .stonetop-row .stonetop-load-heavy {
  pointer-events: none;
}

input[name="attr_loadmirror"][value="heavy"] ~ .stonetop-row .stonetop-load-normal,
input[name="attr_loadmirror"][value="heavy"] ~ .stonetop-row .stonetop-load-heavy {
  opacity: 1;
}

/* ========== STAGE 2: HARDCODED ITEM CHECKLISTS (LARGE / SMALL) ========== */

.stonetop-large-items-list,
.stonetop-small-items-list {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: 8px;
}

.stonetop-item-check {
  align-items: baseline;
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  font-size: 0.78em;
  font-weight: normal;
  line-height: 1.3;
  padding: 1px 0;
  cursor: pointer;
}

.stonetop-item-check strong {
  font-weight: bold;
  color: #1a1a1a;
}

.stonetop-item-check .tracker-label {
  font-size: 0.92em;
  color: #888;
}

.stonetop-item-check input[type="checkbox"] {
  flex: none;
  margin: 0 2px 0 0;
}

/* ========== STAGE 2b: LIVE LOAD TOTAL ========== */

.stonetop-undefined-pool {
  align-items: center;
  flex-wrap: wrap;
}

.stonetop-undefined-tracker input[type="checkbox"] {
  cursor: default;
}

input[name="attr_loadover"][value="1"] ~ .stonetop-row .stonetop-undefined-tracker input[type="checkbox"]:checked {
  accent-color: #9b1a1a;
  outline: 1px solid #9b1a1a;
}

/* ========== STAGE 2d: SMALL ITEMS CAPACITY TRACKER ========== */

.stonetop-small-capacity-tracker input[type="checkbox"] {
  cursor: default;
}

input[name="attr_smallover"][value="1"] ~ .stonetop-row .stonetop-small-capacity-tracker input[type="checkbox"]:checked {
  accent-color: #9b1a1a;
  outline: 1px solid #9b1a1a;
}

.stonetop-large-items-list h4,
.stonetop-small-items-list h4,
.stonetop-column-thirds h4 {
  margin: 10px 0 4px 0;
  font-size: 0.85em;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #555;
}

.stonetop-small-items-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px 8px;
}

/* ========== SPECIAL POSSESSIONS ========== */

.stonetop-special-possessions {
  margin-top: 24px;
  border-top: 2px solid #3a3a46;
  padding-top: 12px;
}

.stonetop-special-possessions h3 {
  margin-top: 0;
}

/* ========== ADDITIONAL MOVES ========== */

.stonetop-additional-moves {
  margin-top: 24px;
  border-top: 2px solid #3a3a46;
  padding-top: 12px;
}

.stonetop-additional-moves h3 {
  margin-top: 0;
}

/* ========== PLAYBOOK COLOR THEMES ========== */

.heavy-section .stonetop-move { border-left-color: #9b1a1a; }
.heavy-section h2 { color: #7a0000; }

.fox-section .stonetop-move { border-left-color: #c8860a; }
.fox-section h2 { color: #8a5a00; }

.ranger-section .stonetop-move { border-left-color: #4a7c4e; }
.ranger-section h2 { color: #2d5c31; }

.blessed-section .stonetop-move { border-left-color: #6b8c3e; }
.blessed-section h2 { color: #3e5c1a; }

.judge-section .stonetop-move { border-left-color: #888888; }
.judge-section h2 { color: #444444; }

.lightbearer-section .stonetop-move { border-left-color: #c8a020; }
.lightbearer-section h2 { color: #8a6a00; }

.marshal-section .stonetop-move { border-left-color: #3a5f8c; }
.marshal-section h2 { color: #1a3a6b; }

.seeker-section .stonetop-move { border-left-color: #6b3a8c; }
.seeker-section h2 { color: #4a1a6b; }

.wbh-section .stonetop-move { border-left-color: #4a90c4; }
.wbh-section h2 { color: #1a5f8a; }

.stonetop-main input[name="attr_activeplaybook"][value="heavy"] ~ .stonetop-header-row .heavy-label { color: #7a0000; }
.stonetop-main input[name="attr_activeplaybook"][value="fox"] ~ .stonetop-header-row .fox-label { color: #8a5a00; }
.stonetop-main input[name="attr_activeplaybook"][value="would-be-hero"] ~ .stonetop-header-row .wbh-label { color: #1a5f8a; }
.stonetop-main input[name="attr_activeplaybook"][value="blessed"] ~ .stonetop-header-row .blessed-label { color: #3e5c1a; }
.stonetop-main input[name="attr_activeplaybook"][value="judge"] ~ .stonetop-header-row .judge-label { color: #444444; }
.stonetop-main input[name="attr_activeplaybook"][value="lightbearer"] ~ .stonetop-header-row .lightbearer-label { color: #8a6a00; }
.stonetop-main input[name="attr_activeplaybook"][value="marshal"] ~ .stonetop-header-row .marshal-label { color: #1a3a6b; }
.stonetop-main input[name="attr_activeplaybook"][value="ranger"] ~ .stonetop-header-row .ranger-label { color: #2d5c31; }
.stonetop-main input[name="attr_activeplaybook"][value="seeker"] ~ .stonetop-header-row .seeker-label { color: #4a1a6b; }

/* ========== ARCANA TAB: SECTION SHOW/HIDE ========== */

/* Hidden by default alongside the other three sections */
.stonetop-main .stonetop-arcana-section {
  position: absolute;
  left: -10000px;
  top: auto;
  width: 1px;
  height: 1px;
  overflow: visible;
}

/* Shown when arcana tab is active */
.stonetop-main .stonetop-tabstoggle[value=arcana] ~ div.stonetop-arcana-section {
  height: auto;
  left: auto;
  position: relative;
  width: auto;
}

/* Active tab button highlight */
.stonetop-main .stonetop-tabstoggle[value=arcana] ~ .stonetop-tabs button.arcana {
  background-color: #3a3a46;
  color: white;
}

/*  ARCANA TAB: LAYOUT & INTRO  */

.arcana-tab-intro {
  font-size: 0.9em;
  color: #555;
  margin-bottom: 20px;
  font-style: italic;
  line-height: 1.5;
}

.arcana-section-heading {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1.4em;
  letter-spacing: 0.04em;
  color: #3a3a46;
  border-bottom: 2px solid #3a3a46;
  padding-bottom: 4px;
  margin: 24px 0 12px 0;
}

/*  ARCANA CARDS: OUTER SHELL  */

.arcana-card {
  border: 2px solid #3a3a46;
  border-radius: 4px;
  margin-bottom: 10px;
  background: #fafafa;
  overflow: hidden;
}

.arcana-card.arcana-major {
  border-left: 5px solid #6b3a8c;
}

.arcana-card.arcana-minor {
  border-left: 5px solid #3a5f8c;
}

/*  ARCANA CARDS: SUMMARY (COLLAPSED VIEW)  */

.arcana-summary {
  display: block;
  cursor: pointer;
  padding: 8px 10px;
  background: #f0f0ec;
  user-select: none;
  list-style: none;
}

.arcana-summary::-webkit-details-marker {
  display: none;
}

.arcana-summary-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.arcana-summary-bottom {
  display: flex;
  align-items: center;
  gap: 12px;
}

.arcana-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1em;
  font-weight: bold;
  color: #3a3a46;
  letter-spacing: 0.02em;
}

.arcana-possessed-wrap {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.85em;
  font-weight: bold;
  color: #6b3a8c;
  cursor: pointer;
}

.arcana-tags {
  font-size: 0.8em;
  font-style: italic;
  color: #777;
}

/*  ARCANA CARDS: EXPANDED BODY  */

.arcana-card-body {
  padding: 12px 14px;
  border-top: 1px solid #ddd;
  position: relative;
}

.arcana-card-body p {
  font-size: 0.88em;
  line-height: 1.55;
  margin: 0 0 8px 0;
  color: #3a3a46;
}

.arcana-card-body ul,
.arcana-card-body ol {
  font-size: 0.88em;
  line-height: 1.55;
  margin: 0 0 8px 16px;
  padding: 0;
}

.arcana-card-body li {
  margin-bottom: 4px;
}

.arcana-card-body strong {
  color: #1a1a1a;
}



/* The checkbox itself is hidden — it's a pure CSS state toggle */
.arcana-unlock-trigger {
  position: absolute;
  left: -10000px;
  top: auto;
  width: 1px;
  height: 1px;
  overflow: hidden;
}

.arcana-unlock-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82em;
  font-weight: bold;
  color: #6b3a8c;
  cursor: pointer;
  margin-bottom: 10px;
  padding: 3px 8px;
  border: 1px solid #6b3a8c;
  border-radius: 3px;
  background: #f7f3fc;
  user-select: none;
}

.arcana-unlock-label::before {
  content: "\2610";
  font-size: 1.1em;
}

.arcana-unlock-trigger:checked ~ .arcana-unlock-label::before {
  content: "\2611";
}

/* Back is hidden until unlocked */
.arcana-back {
  display: none;
}

.arcana-unlock-trigger:checked ~ .arcana-back {
  display: block;
}

/* ========== ARCANA CARDS: FRONT CONTENT ========== */

.arcana-front {
  margin-top: 4px;
}

.arcana-req-heading {
  font-size: 0.82em;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #555;
  margin: 10px 0 4px 0;
}

.arcana-requirements {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin: 0 0 10px 0;
}

.arcana-requirements label {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 0.85em;
  line-height: 1.45;
  color: #3a3a46;
  cursor: pointer;
  font-weight: normal;
}

.arcana-requirements label input[type="checkbox"] {
  flex: none;
  margin-top: 2px;
}

/* ========== ARCANA CARDS: BACK CONTENT ========== */

.arcana-back-heading {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1em;
  font-weight: bold;
  font-style: italic;
  color: #3a3a46;
  border-bottom: 1px solid #bbb;
  padding-bottom: 4px;
  margin: 0 0 10px 0;
}

.arcana-effects-track {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 8px 0;
}

.arcana-effects-track label {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 0.85em;
  line-height: 1.45;
  color: #3a3a46;
  cursor: pointer;
  font-weight: normal;
}

.arcana-effects-track label input[type="checkbox"] {
  flex: none;
  margin-top: 2px;
}

.arcana-effects-track span {
  font-size: 0.85em;
  color: #555;
}


.stonetop-arcana-section label {
  color: #333333 !important;
}
