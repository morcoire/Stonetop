/* Stonetop character sheet for Roll20. Based on Stonetop by Jeremy Strandberg, CCBYSA 4.0. Sheet customizations by Morcoire. */

.stonetop-main {
  display: flex;
  flex-direction: column;
}

.stonetop-main,
.stonetop-main * {
  box-sizing: border-box;
  color: #3a3a46;
  font-family: Georgia, 'Times New Roman', serif;
}

.stonetop-main input,
.stonetop-main select,
.stonetop-main textarea,
.stonetop-main button {
  font-family: 'DM Sans', sans-serif;
}

.stonetop-main h2 {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1.6em;
  letter-spacing: 0.04em;
  margin-bottom: 4px;
}

.stonetop-main h3 {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1em;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin: 20px 0px;
}

.stonetop-main h4 {
  font-family: Georgia, 'Times New Roman', serif;
  letter-spacing: 0.03em;
}

.stonetop-main .stonetop-tabs button {
  font-family: Georgia, 'Times New Roman', serif;
  letter-spacing: 0.05em;
}

.stonetop-main .stonetop-sr-only {
  position: absolute;
  left: -10000px;
  top: auto;
  width: 1px;
  height: 1px;
  overflow: hidden;
}

.stonetop-main .stonetop-tabs {
  border-bottom: 2px solid #3a3a46;
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}

.stonetop-main .stonetop-tabs button {
  background-color: white;
  border: 2px solid #3a3a46;
  border-bottom: none;
  border-radius: 5px 5px 0px 0px;
  color: #3a3a46;
  cursor: pointer;
  font: inherit;
  height: 3em;
  margin: 0px 5px;
  outline: inherit;
  padding: 5px;
}

.stonetop-main .stonetop-character-section,
.stonetop-main .stonetop-followers-section,
.stonetop-main .stonetop-inventory-section {
  position: absolute;
  left: -10000px;
  top: auto;
  width: 1px;
  height: 1px;
  overflow: visible;
}

.stonetop-main .stonetop-tabstoggle[value=character] ~ div.stonetop-character-section,
.stonetop-main .stonetop-tabstoggle[value=inventory] ~ div.stonetop-inventory-section,
.stonetop-main .stonetop-tabstoggle[value=followers] ~ div.stonetop-followers-section {
  height: auto;
  left: auto;
  position: relative;
  width: auto;
}

.stonetop-main .stonetop-tabstoggle[value=character] ~ .stonetop-tabs button.character,
.stonetop-main .stonetop-tabstoggle[value=inventory] ~ .stonetop-tabs button.inventory,
.stonetop-main .stonetop-tabstoggle[value=followers] ~ .stonetop-tabs button.followers {
  background-color: #3a3a46;
  color: white;
}

.stonetop-main .stonetop-row {
  display: flex;
  align-items: center;
}

.stonetop-main .stonetop-column-thirds {
  align-self: flex-start;
  flex: 0 0 auto;
  margin-right: 30px;
  width: calc(33% - 30px * 2 / 3);
}

.stonetop-main .stonetop-column-thirds:last-of-type {
