/* ========== OCTAGON BORDER ========== */

.octagon {
  border-color: white;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: white;
  z-index: 2;
}

.octagon.bg {
  border-color: #3a3a46;
  position: absolute;
  top: -2px;
  left: -2px;
  width: calc(100% + 4px);
  height: calc(100% + 4px);
  background: #3a3a46;
  z-index: 1;
}

.octagon.bg::before {
  top: -23px;
  border-bottom: 23px solid;
  border-bottom-color: inherit;
  border-left: 23px solid transparent;
  border-right: 23px solid transparent;
  width: calc(100% - 46px);
}

.octagon.bg::after {
  bottom: -23px;
  border-top: 23px solid;
  border-top-color: inherit;
  border-left: 23px solid transparent;
  border-right: 23px solid transparent;
  width: calc(100% - 46px);
}

.octagon:before {
  content: "";
  position: absolute;
  top: -22px;
  left: 0px;
  width: calc(100% - 44px);
  height: 0px;
  border-bottom: 22px solid;
  border-bottom-color: inherit;
  border-left: 22px solid transparent;
  border-right: 22px solid transparent;
  z-index: 3;
  color: #ecf0f1;
  font-size: 20px;
  text-align: center;
  font-weight: bold;
}

.octagon:after {
  content: "";
  position: absolute;
  bottom: -22px;
  right: 0px;
  width: calc(100% - 44px);
  height: 0px;
  border-top: 22px solid;
  border-top-color: inherit;
  border-right: 22px solid transparent;
  border-left: 22px solid transparent;
  z-index: 1;
}

