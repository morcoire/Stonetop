<script type="text/worker">
  on('change:hpmax change:damagetaken sheet:opened', () => {
    getAttrs(['hpmax', 'damagetaken'], (attrs) => {
      setAttrs({ hp: (parseInt(attrs.hpmax) || 0) - (parseInt(attrs.damagetaken) || 0) });
    });
  });

  on('clicked:character clicked:inventory clicked:followers', (e) => {
    setAttrs({ sheetTab: e.triggerName.replace('clicked:', '') });
  });

   on('change:class sheet:opened', () => {
    getAttrs(['class'], (attrs) => {
      const val = attrs['class'] || 'none';
      setAttrs({ activeplaybook: val, activeplaybook_inv: val });
    });
  });
</script>
